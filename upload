#!/bin/bash

# Arduino Upload Script
# Automatically uploads the sketch matching the folder name
# Uses port from .vscode/arduino.json

set -e  # Exit on error

# Get the folder name (sketch name)
FOLDER_NAME=$(basename "$PWD")
SKETCH_NAME="${FOLDER_NAME}.ino"

# Check if sketch exists
if [ ! -f "$SKETCH_NAME" ]; then
    echo "Error: Sketch file '$SKETCH_NAME' not found!"
    exit 1
fi

# Parse port from arduino.json
if [ -f ".vscode/arduino.json" ]; then
    PORT=$(grep -o '"port": *"[^"]*"' .vscode/arduino.json | sed 's/"port": *"\([^"]*\)"/\1/')
    BOARD=$(grep -o '"board": *"[^"]*"' .vscode/arduino.json | sed 's/"board": *"\([^"]*\)"/\1/')
else
    echo "Error: .vscode/arduino.json not found!"
    exit 1
fi

# Check if port was found
if [ -z "$PORT" ]; then
    echo "Error: Could not find port in arduino.json"
    exit 1
fi

# Check if board was found
if [ -z "$BOARD" ]; then
    echo "Error: Could not find board in arduino.json"
    exit 1
fi

echo "================================================"
echo "Arduino Upload Script"
echo "================================================"
echo "Sketch: $SKETCH_NAME"
echo "Board:  $BOARD"
echo "Port:   $PORT"
echo "================================================"

# Compile
echo ""
echo "Compiling..."
arduino-cli compile --fqbn "$BOARD" "$SKETCH_NAME"

if [ $? -eq 0 ]; then
    echo ""
    echo "Compilation successful!"
    echo ""
    
    # Upload
    echo "Uploading to $PORT..."
    arduino-cli upload -p "$PORT" --fqbn "$BOARD" "$SKETCH_NAME"
    
    if [ $? -eq 0 ]; then
        echo ""
        echo "================================================"
        echo "✓ Upload successful!"
        echo "================================================"
    else
        echo ""
        echo "================================================"
        echo "✗ Upload failed!"
        echo "================================================"
        echo ""
        echo "Common fixes:"
        echo "  1. Close Serial Monitor"
        echo "  2. Check if Arduino is connected"
        echo "  3. Verify correct port in .vscode/arduino.json"
        exit 1
    fi
else
    echo ""
    echo "================================================"
    echo "✗ Compilation failed!"
    echo "================================================"
    exit 1
fi
